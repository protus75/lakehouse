    create  table
      "lakehouse"."silver_tabletop"."silver_files__dbt_tmp"
  
    as (
      -- Silver file-level metadata aggregated from entries

select
    e.source_file,
    f.pdf_size_bytes,
    f.total_pages,
    count(*) as total_entries,
    count(case when e.entry_title is not null then 1 end) as named_entries,
    sum(e.char_count) as total_chars,
    current_timestamp as processed_at
from "lakehouse"."silver_tabletop"."silver_entries" e
