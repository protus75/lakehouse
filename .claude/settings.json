{
  "env": {
    "CLAUDE_TMPDIR": "D:\\Claude\\Temp"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(docker compose:*)",
      "Bash(docker exec:*)",
      "Bash(docker images:*)",
      "Bash(docker info:*)",
      "Bash(docker logs:*)",
      "Bash(docker port:*)",
      "Bash(docker ps:*)",
      "Bash(docker restart:*)",
      "Bash(docker start:*)",
      "Bash(docker stats:*)",
      "Bash(docker stop:*)",
      "Bash(docker top:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(nvidia-smi:*)",
      "Bash(ollama:*)",
      "Bash(pip install:*)",
      "Bash(powershell:*)",
      "Bash(python -c:*)",
      "Bash(python -u:*)",
      "Bash(python scripts/:*)",
      "Bash(python3:*)",
      "Bash(rm scripts/:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(wsl:*)",
      "Bash(xargs:*)",
      "Skill(update-config:*)",
      "WebFetch(domain:ollama.com)",
      "WebFetch(domain:polaris.apache.org)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import sys,json; d=json.load(sys.stdin); f=d.get('tool_response',{}).get('filePath','') or d.get('tool_input',{}).get('file_path',''); exit(0 if 'streamlit/' in f else 1)\" && docker exec lakehouse-workspace bash -c 'grep -rl streamlit /proc/[0-9]*/cmdline 2>/dev/null | grep -oP \"/proc/\\K[0-9]+\" | xargs -r kill -9 2>/dev/null; find /workspace/streamlit -name __pycache__ -type d -exec rm -rf {} + 2>/dev/null; sleep 1; cd /workspace && nohup streamlit run streamlit/app.py --server.port 8501 --server.address 0.0.0.0 > /dev/null 2>&1 &' || true",
            "timeout": 15,
            "statusMessage": "Restarting Streamlit..."
          }
        ]
      }
    ]
  },
  "autoMemoryDirectory": "D:\\source\\lakehouse\\lakehouse\\.claude-memory"
}
